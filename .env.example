# ===========================================
# UMAI Booking System - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-domain.com

# Database (PostgreSQL 16+)
DATABASE_URL=postgresql://user:password@localhost:5432/umai_booking

# Authentication
JWT_SECRET=change-this-to-a-random-64-char-string

# Google Calendar OAuth (per-staff calendar sync)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/admin/staff/google/callback

# Legacy Google Calendar (service account - optional, for single-calendar mode)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_CALENDAR_ID=

# Email (SMTP - for booking confirmations and password resets)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=UMAI <noreply@umai.io>
